{
    "Format": "2.9.0",
    "Changes": [
        // define language
        {
            "Action": "EditData",
            "Target": "Data/AdditionalLanguages",
            "Entries": {
                "{{ModId}}_Esperanto": { // for technical reasons, you need to specify the ID here *and* in the "ID" field
                    "ID": "{{ModId}}_Cymraeg",
                    "LanguageCode": "cy",
                    "ButtonTexture": "Mods/{{ModId}}/Button",
                    "UseLatinFont": true,
                    "TimeFormat": "[HOURS_12]:[MINUTES] [AM_PM]",
                    "ClockTimeFormat": "[HOURS_12]:[MINUTES]",
                    "ClockDateFormat": "[DAY_OF_WEEK] [DAY_OF_MONTH]",
                    "UseGenderedCharacterTranslations": true,
                }
            }
        },

        // load button texture
        {
            "Action": "Load",
            "Target": "Mods/{{ModId}}/Button",
            "FromFile": "assets/button.png"
        },


